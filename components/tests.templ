package components

import "strconv"

func intToStr(i int) string {
	return strconv.Itoa(i)
}

var Dual1 = DefineSlot[string]()
var Dual2 = DefineSlot[string]()

templ DualSlot() {
	<h1>
		@Dual1 {
			{ children... }
		}
	</h1>
	<p>
		@Dual2 {
			{ children... }
		}
	</p>
}

